{
  "cleanupPeriodDays": 9999,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Bash(cargo check:*)",
      "Bash(gh issue list *)",
      "Bash(gh issue view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr view *)",
      "Bash(gh run list *)",
      "Bash(gh run view *)",
      "Bash(gh pr checks *)",
      "Bash(gh release list *)",
      "Bash(gh release view *)",
      "Bash(gh repo view *)",
      "Bash(gh search *)",
      "Bash(git :*)",
      "Bash(ls:*)",
      "Bash(npm run :*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(npx tsc:*)",
      "Bash(obsidian *)",
      "Bash(osascript *)",
      "Bash(printf *)",
      "Bash(yarn :*)",
      "Skill(moqada-commit)",
      "Skill(agent-browser)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:renovatebot.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:qiita.com)",
      "WebFetch(domain:zenn.com)",
      "WebSearch",
      "mcp__claude_ai_Figma__get_code_connect_map",
      "mcp__claude_ai_Figma__get_code_connect_suggestions",
      "mcp__claude_ai_Figma__get_context_for_code_connect",
      "mcp__claude_ai_Figma__get_design_context",
      "mcp__claude_ai_Figma__get_figjam",
      "mcp__claude_ai_Figma__get_metadata",
      "mcp__claude_ai_Figma__get_screenshot",
      "mcp__claude_ai_Figma__get_variable_defs",
      "mcp__claude_ai_Notion__notion-fetch",
      "mcp__claude_ai_Notion__notion-get-comments",
      "mcp__claude_ai_Notion__notion-get-teams",
      "mcp__claude_ai_Notion__notion-get-users",
      "mcp__claude_ai_Notion__notion-search",
      "mcp__claude_ai_Notion__notion-query-data-sources",
      "mcp__claude_ai_Notion__notion-query-meeting-notes",
      "mcp__notion__notion-fetch",
      "mcp__notion__notion-get-comments",
      "mcp__notion__notion-get-teams",
      "mcp__notion__notion-get-users",
      "mcp__notion__notion-search",
      "mcp__notion__notion-query-data-sources",
      "mcp__notion__notion-query-meeting-notes",
      "mcp__plugin_figma_figma__get_code_connect_map",
      "mcp__plugin_figma_figma__get_code_connect_suggestions",
      "mcp__plugin_figma_figma__get_context_for_code_connect",
      "mcp__plugin_figma_figma__get_design_context",
      "mcp__plugin_figma_figma__get_figjam",
      "mcp__plugin_figma_figma__get_metadata",
      "mcp__plugin_figma_figma__get_screenshot",
      "mcp__plugin_figma_figma__get_variable_defs",
      "mcp__plugin_Notion_notion__notion-fetch",
      "mcp__plugin_Notion_notion__notion-get-comments",
      "mcp__plugin_Notion_notion__notion-get-teams",
      "mcp__plugin_Notion_notion__notion-get-users",
      "mcp__plugin_Notion_notion__notion-search",
      "mcp__plugin_Notion_notion__notion-query-data-sources",
      "mcp__plugin_Notion_notion__notion-query-meeting-notes"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Read(~/.ssh/**)",
      "Read(~/.zshenv)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/.envrc)",
      "Read(**/secrets/**)",
      "Read(**/android/app/*.keystore)",
      "Read(**/ios/**/Certificates/**)",
      "Read(~/.aws/**)",
      "Read(~/.npmrc)",
      "Read(~/.config/gh/**)",
      "Read(~/.docker/**)",
      "Read(~/.kube/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.netrc)"
    ],
    "ask": [
      "Bash(gh issue close *)",
      "Bash(gh issue comment *)",
      "Bash(gh issue create *)",
      "Bash(gh issue edit *)",
      "Bash(gh pr close *)",
      "Bash(gh pr comment *)",
      "Bash(gh pr create *)",
      "Bash(gh pr edit *)",
      "Bash(gh pr merge *)",
      "Bash(gh pr review *)",
      "Bash(gh release create *)",
      "Bash(git push *)",
      "mcp__claude_ai_Notion__notion-create-comment",
      "mcp__claude_ai_Notion__notion-create-database",
      "mcp__claude_ai_Notion__notion-create-pages",
      "mcp__claude_ai_Notion__notion-create-view",
      "mcp__claude_ai_Notion__notion-duplicate-page",
      "mcp__claude_ai_Notion__notion-move-pages",
      "mcp__claude_ai_Notion__notion-update-data-source",
      "mcp__claude_ai_Notion__notion-update-page",
      "mcp__claude_ai_Notion__notion-update-view",
      "mcp__notion__notion-create-comment",
      "mcp__notion__notion-create-database",
      "mcp__notion__notion-create-pages",
      "mcp__notion__notion-create-view",
      "mcp__notion__notion-duplicate-page",
      "mcp__notion__notion-move-pages",
      "mcp__notion__notion-update-data-source",
      "mcp__notion__notion-update-page",
      "mcp__notion__notion-update-view"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // empty') && if echo \"$cmd\" | grep -qE 'git[[:space:]]+(checkout[[:space:]]+-b|switch[[:space:]]+-c)[[:space:]]+[^[:space:]]+[[:space:]]+origin/' && ! echo \"$cmd\" | grep -q -- '--no-track'; then echo 'BLOCK: git checkout -b <branch> origin/... は --no-track を付けてください。tracking branch が origin/master 等に設定され、push 時に意図せず master に push されるリスクがあります。'; exit 2; fi"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.bin/claude-notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "dig@kuu-marketplace": true,
    "code-review@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "agent-browser@agent-browser": true,
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "obsidian@obsidian-skills": true,
    "notion@claude-plugins-official": true,
    "figma@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "agent-browser": {
      "source": {
        "source": "github",
        "repo": "vercel-labs/agent-browser"
      }
    },
    "kuu-marketplace": {
      "source": {
        "source": "github",
        "repo": "fumiya-kume/claude-code"
      }
    }
  },
  "language": "Japanese",
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "codex:*",
      "docker",
      "gh:*",
      "npx jest:*",
      "obsidian:*",
      "yarn jest:*"
    ]
  },
  "alwaysThinkingEnabled": true,
  "voiceEnabled": true,
  "effortLevel": "high"
}
